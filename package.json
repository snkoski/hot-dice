{
  "name": "hot-dice",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "description": "Farkle/Hot Dice game simulator with pluggable strategy system",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:client": "vite build",
    "dev": "tsx watch src/web/server.ts",
    "dev:client": "vite",
    "cursors": "node ../multi-mouse/packages/server/dist/cli.js --port 3001",
    "start": "tsx src/web/server.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "farkle",
    "hot-dice",
    "dice-game",
    "simulator"
  ],
  "author": "Shawn Koski",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@multi-mouse/client": "file:../multi-mouse/packages/client",
    "fastify": "^5.7.1",
    "seedrandom": "^3.0.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/seedrandom": "^3.0.8",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vitest": "^1.0.0"
  }
}
